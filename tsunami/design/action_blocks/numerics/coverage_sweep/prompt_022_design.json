{
  "meta": {
    "title": "Open-World Sandbox City",
    "shape": "sandbox",
    "vibe": ["open-world", "missions", "vehicles", "hub"],
    "target_session_sec": 3600
  },
  "config": {
    "mode": "3d",
    "camera": "perspective",
    "gravity": [0, -9.81, 0],
    "playfield": { "kind": "continuous", "arena": { "shape": "rect", "size": 120 } },
    "sandbox": true
  },
  "singletons": {
    "city": {
      "components": ["WorldFlags"],
      "exposes": { "wanted_level": "number", "missions_done": "number" }
    }
  },
  "archetypes": {
    "player": {
      "mesh": "capsule",
      "controller": "topdown",
      "components": ["Health(100)", "Score", "Inventory",
                     "Resource(cash, 0)", "Resource(wanted, 0)"],
      "tags": ["player"]
    },
    "police": {
      "mesh": "capsule",
      "ai": "chase",
      "components": ["Health(40)"],
      "tags": ["enemy", "police"],
      "trigger": {
        "kind": "damage",
        "contact_side": "any",
        "on_contact": { "kind": "damage", "archetype": "player", "amount": 10 }
      }
    },
    "mission_npc": {
      "mesh": "capsule",
      "controller": "none",
      "components": [],
      "tags": ["npc", "mission_giver"],
      "trigger": {
        "kind": "hit",
        "contact_side": "any",
        "on_contact": { "kind": "dialog", "tree_ref": "npc_dialog", "entry_node": "root" }
      }
    },
    "collectible": {
      "mesh": "sphere",
      "controller": "none",
      "components": [],
      "tags": ["pickup"],
      "trigger": {
        "kind": "pickup",
        "contact_side": "any",
        "on_contact": { "kind": "award_score", "amount": 50 },
        "exclusive": true
      }
    }
  },
  "mechanics": [
    {
      "id": "npc_dialog",
      "type": "DialogTree",
      "params": {
        "trigger_archetype": "mission_npc",
        "tree": {
          "id": "root",
          "speaker": "Contact",
          "line": "Got a job if you want it.",
          "choices": [
            { "text": "Tell me more.", "goto": "brief",
              "effect": { "kind": "emit", "condition": "mission_accepted" } },
            { "text": "Not today.", "goto": "end" }
          ]
        }
      }
    },
    {
      "id": "collectibles",
      "type": "PickupLoop",
      "params": {
        "archetype": "collectible",
        "reward_field": "Score",
        "reward_amount": 50,
        "respawn": "never",
        "max_simultaneous": 100
      }
    },
    {
      "id": "cop_heat",
      "type": "TimedStateModifier",
      "params": {
        "archetype": "player",
        "state": "wanted",
        "duration_sec": 60,
        "stackable": false
      }
    },
    {
      "id": "hud",
      "type": "HUD",
      "params": {
        "fields": [
          { "archetype": "player",  "component": "Health", "label": "HP" },
          { "archetype": "player",  "component": "Resource(cash)", "label": "$" },
          { "singleton": "city",    "field": "wanted_level", "label": "Wanted" },
          { "singleton": "city",    "field": "missions_done", "label": "Missions" }
        ],
        "layout": "corners"
      }
    },
    {
      "id": "lose",
      "type": "LoseOnZero",
      "params": { "archetype": "player", "field": "Health", "emit_condition": "busted" }
    },
    {
      "id": "camera",
      "type": "CameraFollow",
      "params": { "target_archetype": "player", "mode": "chase_3d",
                   "offset": [0, 4, -6], "ease": 0.4 }
    }
  ],
  "flow": {
    "kind": "scene",
    "name": "city",
    "children": [
      { "kind": "scene", "name": "mission_interior" },
      { "kind": "scene", "name": "hospital", "condition": "busted" }
    ]
  }
}
