 def load_env_prefix(prefix: str) -> Params:
+    """Load env vars with given prefix into a nested dict.
+    Use `__` as the nesting delimiter: CFG_APP__NAME -> {app: {name: ...}}.
+    """
     out: Params = {}
     for k, v in os.environ.items():
         if k.startswith(prefix):
             key = k[len(prefix):].lower()
-            out[key] = v
+            parts = key.split('__')
+            d = out
+            for p in parts[:-1]:
+                d = d.setdefault(p, {})
+            d[parts[-1]] = v
     return out
 
 
