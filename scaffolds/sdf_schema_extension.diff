+
+// ───────── SDF substrate types (new 2026-04-27) ─────────
+
+export interface SdfSpec {
+  primitives: SdfPrimitive[]
+  blendGroups?: Record<string, { blend: number }>
+  palette?: Record<string, string>                 // slot name → hex color (e.g. "skin": "#fdb89e")
+}
+
+export type SdfPrimitiveType =
+  | 'sphere' | 'box' | 'capsule' | 'cone' | 'ellipsoid' | 'rounded_box'
+
+export interface SdfPrimitive {
+  type: SdfPrimitiveType
+  // Shape parameters (varies by type):
+  radius?: number                                  // sphere/capsule/cone
+  height?: number                                  // capsule/cone
+  halfExtents?: [number, number, number]           // box/rounded_box/ellipsoid
+  halfAngleSin?: number; halfAngleCos?: number     // cone
+  // Common:
+  offset: [number, number, number]
+  rotation?: [number, number, number, number]      // quaternion [x,y,z,w]
+  paletteSlot: string                              // key into SdfSpec.palette
+  blendGroup?: string                              // key into SdfSpec.blendGroups (smin within group, min across)
+  colorFunc?: 'flat' | 'gradientY' | 'pulsate' | 'radialFade' | 'stripes' | 'dots' | 'checker'
+}
+
+export type RenderContextCamera =
+  | 'iso'                       // top-down 26.57° dimetric (action_adventure, jrpg-overworld, stealth)
+  | 'side'                      // pure side-view (platformer, fighting)
+  | 'side_25d'                  // side-view + faux-Z depth (beat_em_up)
+  | 'side_view'                 // jrpg battle (large battler facing right)
+  | 'front'                     // portrait / dialogue head crop
+  | 'perspective_billboard'     // first-person FPS, 8-direction Doom-style
+
+export interface RenderContext {
+  camera: RenderContextCamera
+  directions: 1 | 2 | 4 | 8                        // pose-cache directional bins
+  anims: string[]                                  // anim names (idle/walk/attack/...)
+  stances?: string[]                               // optional, e.g. stealth's [stand|crouch|prone]
+  scale?: number                                   // default 1.0
+}
+
+export interface PixelGridRef {
+  preset?: string                                  // e.g. "knight_neutral_face" — looked up in pixel-grid library
+  inline?: number[][]                              // 2D array of palette indices (alternative to preset)
+  palette?: string[]                               // 7-slot palette per face_pixels.ts pattern
 }
 
