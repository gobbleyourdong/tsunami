{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Sample record",
  "type": "object",
  "required": ["id", "user", "status"],
  "properties": {
    "id":     { "type": "integer" },
    "user":   {
      "type": "object",
      "required": ["name", "city"],
      "properties": {
        "name": { "type": "string" },
        "city": { "type": "string" }
      }
    },
    "status": { "type": "string", "enum": ["active", "inactive"] },
    "score":  { "type": "number", "minimum": 0, "maximum": 1 }
  }
}
