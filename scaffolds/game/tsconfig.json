{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "types": ["@webgpu/types"],
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "paths": {
      "@engine/*": ["../../engine/src/*"],
      "@engine": ["../../engine/src/index.ts"]
    }
  },
  "include": ["src"]
}
