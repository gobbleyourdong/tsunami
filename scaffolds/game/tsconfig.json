{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "isolatedModules": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "types": ["@webgpu/types", "vite/client"],
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "paths": {
      "@engine/*": ["../engine/src/*"],
      "@engine": ["../engine/src/index.ts"],
      "tsunami-engine": ["../engine/src/index.ts"],
      "tsunami-engine/*": ["../engine/src/*"]
    }
  },
  "include": ["src"]
}
