#!/usr/bin/env python3
"""
tsunami — the tide rises

Usage:
    tsunami                # Interactive REPL (default)
    tsunami --task "..."   # Run single task and exit
    tsunami --web          # Web UI on port 3000
"""

import argparse
import asyncio
import ctypes
import logging
import os
import signal
import subprocess
import sys
import time

SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
sys.path.insert(0, SCRIPT_DIR)
os.chdir(SCRIPT_DIR)

BANNER = """\033[1m
▀▛▘▞▀▖▌ ▌▙ ▌▞▀▖▙▗▌▜▘
 ▌ ▚▄ ▌ ▌▌▌▌▙▄▌▌▘▌▐
 ▌ ▖ ▌▌ ▌▌▝▌▌ ▌▌ ▌▐
 ▘ ▝▀ ▝▀ ▘ ▘▘ ▘▘ ▘▀▘\033[0m
\033[1;38;2;74;158;255m the tide rises\033[0m
"""

DIM = "\033[2m"
RST = "\033[0m"
GREEN = "\033[32m"
RED = "\033[31m"


def check_model_server(endpoint):
    try:
        import httpx
        return httpx.get(f"{endpoint}/health", timeout=3).status_code == 200
    except Exception:
        return False


def start_model_server(config):
    """Start serve_transformers.py with the first HF model dir found."""
    models_dir = os.path.join(SCRIPT_DIR, "models")
    serve_script = os.path.join(SCRIPT_DIR, "serve_transformers.py")
    if not os.path.exists(models_dir) or not os.path.exists(serve_script):
        return None

    # Find HF model directory — prefer most recently modified (latest champion)
    model_dir = None
    candidates = []
    for d in os.listdir(models_dir):
        full = os.path.join(models_dir, d)
        if os.path.isdir(full) and os.path.exists(os.path.join(full, "config.json")):
            candidates.append(full)
    if candidates:
        model_dir = max(candidates, key=lambda p: os.path.getmtime(p))
    if not model_dir:
        return None

    port = config.model_endpoint.split(":")[-1].rstrip("/")
    print(f"  {DIM}starting model: {os.path.basename(model_dir)}{RST}")

    # Linux: ensure child dies if we get SIGTERM'd (else child loads 4GB then orphan-fails)
    def _set_pdeathsig():
        try:
            libc = ctypes.CDLL("libc.so.6", use_errno=True)
            libc.prctl(1, signal.SIGTERM, 0, 0, 0)  # PR_SET_PDEATHSIG = 1
        except Exception:
            pass

    popen_kwargs = dict(stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    if sys.platform.startswith("linux"):
        popen_kwargs["preexec_fn"] = _set_pdeathsig
    proc = subprocess.Popen(
        [sys.executable, serve_script, "--model", model_dir, "--port", port],
        **popen_kwargs)

    for _ in range(120):
        time.sleep(1)
        if check_model_server(config.model_endpoint):
            if proc and proc.poll() is not None:  # ours died, but something else is answering
                proc.wait()
                return None
            return proc
        if proc and proc.poll() is not None:  # child died (bind probe rejected); reap, then keep
            proc.wait()                        # polling — the existing server holding the port may recover
            proc = None
    return proc


# ── Tool action labels ──
TOOL_LABELS = {
    "file_read": "reading", "file_write": "writing", "file_edit": "editing",
    "file_append": "appending", "file_view": "viewing", "match_glob": "searching",
    "match_grep": "grepping", "shell_exec": "running", "shell_view": "checking",
    "shell_kill": "killing", "search_web": "searching web",
    "browser_navigate": "navigating", "browser_view": "viewing page",
    "plan_update": "planning", "plan_advance": "advancing plan",
    "project_init": "scaffolding", "undertow": "QA testing",
    "generate_image": "generating image", "swell_build": "dispatching eddies",
    "message_chat": "thinking", "message_info": "thinking",
    "message_result": "delivering", "message_ask": "asking",
}


def _short_path(p):
    """Just the filename, not the whole path."""
    return str(p).replace("\\", "/").rsplit("/", 1)[-1][:40] if p else ""


def action_label(name, args):
    base = TOOL_LABELS.get(name, name.replace("_", " "))
    if name == "shell_exec":
        cmd = str(args.get("command", "")).strip()
        # Show just the last command after && or ;
        last = cmd.split("&&")[-1].split(";")[-1].strip()
        short = (last[:40] + "…") if len(last) > 40 else last
        return f"{base} {short}" if short else base
    if name == "undertow":
        levers = args.get("levers", [])
        if isinstance(levers, list) and levers:
            actions = [l.get("action", "?") if isinstance(l, dict) else "?" for l in levers]
            return f"QA: {', '.join(actions)}"
        return "QA testing"
    detail = args.get("path") or args.get("query") or args.get("pattern") or args.get("name") or ""
    return f"{base} {_short_path(detail)}" if detail else base


def patch_agent(agent):
    original = agent._step

    async def step_with_actions(_watcher_depth=0):
        result = await original(_watcher_depth=_watcher_depth)
        for m in reversed(agent.state.conversation):
            if m.tool_call and isinstance(m.tool_call, dict):
                func = m.tool_call.get("function", {})
                name = func.get("name", "")
                if name.startswith("message_"):
                    break
                args = func.get("arguments", {})
                label = action_label(name, args)
                print(f"  {DIM}● {label}{RST}")
                break
        return result

    agent._step = step_with_actions


def main():
    parser = argparse.ArgumentParser(description="tsunami — the tide rises")
    parser.add_argument("--task", type=str, help="Run single task and exit")
    parser.add_argument("--web", action="store_true", help="Web UI")
    parser.add_argument("--port", type=int, default=3000)
    parser.add_argument("--model", type=str)
    parser.add_argument("--endpoint", type=str)
    parser.add_argument("--verbose", "-v", action="store_true")
    args = parser.parse_args()

    if args.verbose:
        logging.basicConfig(
            level=logging.DEBUG,
            format="%(asctime)s %(name)s %(message)s", datefmt="%H:%M:%S")
    else:
        # Silence all logging in user-facing mode — no internal state leakage
        logging.basicConfig(level=logging.CRITICAL + 1)

    from tsunami.config import TsunamiConfig
    config = TsunamiConfig.from_yaml(os.path.join(SCRIPT_DIR, "config.yaml"))
    config = TsunamiConfig.from_env(config)

    if args.model:
        config.model_name = args.model
    if args.endpoint:
        config.model_endpoint = args.endpoint

    print(BANNER)

    model_proc = None
    if not check_model_server(config.model_endpoint):
        model_proc = start_model_server(config)
        if not model_proc:
            print(f"  {RED}no model at {config.model_endpoint}{RST}")
    else:
        print(f"  {DIM}{config.model_endpoint}{RST}")
    print()

    # ── Single task ──
    if args.task:
        from tsunami.agent import Agent
        agent = Agent(config)
        patch_agent(agent)
        asyncio.run(agent.run(args.task))
        print()
        if model_proc:
            model_proc.terminate()
        return

    # ── Web UI ──
    if args.web:
        print(f"  http://localhost:{args.port}")
        try:
            from tsunami.server import start_server
            start_server(host="0.0.0.0", port=args.port)
        except KeyboardInterrupt:
            pass
        finally:
            if model_proc:
                model_proc.terminate()
        return

    # ── Interactive REPL (default) ──
    from prompt_toolkit import PromptSession
    from prompt_toolkit.key_binding import KeyBindings
    from prompt_toolkit.keys import Keys
    from prompt_toolkit.styles import Style

    style = Style.from_dict({
        "prompt": "bg:#2a2a3a #ffffff",
        "": "bg:#1a1a2a #e0e0e8",
    })

    bindings = KeyBindings()

    @bindings.add(Keys.Enter)
    def submit(event):
        event.current_buffer.validate_and_handle()

    @bindings.add(Keys.ControlJ)  # Shift+Enter in many terminals
    def newline(event):
        event.current_buffer.insert_text("\n")

    session = PromptSession(
        message="  ",
        style=style,
        key_bindings=bindings,
        multiline=True,
        prompt_continuation="  ",
    )

    from tsunami.tools.message import set_input_callback

    async def agent_ask_input(prompt):
        loop = asyncio.get_event_loop()
        return await loop.run_in_executor(None, lambda: session.prompt(f"  {DIM}? {RST}"))

    set_input_callback(agent_ask_input)

    async def repl():
        from tsunami.agent import Agent

        active_project = None

        while True:
            try:
                prefix = f"  {DIM}[{active_project}]{RST} " if active_project else "  "
                text = await asyncio.get_event_loop().run_in_executor(
                    None, lambda: session.prompt()
                )
            except (EOFError, KeyboardInterrupt):
                break

            text = text.strip()
            if not text:
                continue
            if text.lower() in ("quit", "exit", "q", "/quit"):
                break

            # ── /project command ──
            if text.startswith("/project"):
                parts = text.split(None, 2)
                if len(parts) == 1:
                    # List projects
                    projects = Agent.list_projects(config.workspace_dir)
                    if not projects:
                        print(f"  {DIM}no projects yet{RST}")
                    else:
                        print(f"  {DIM}Projects:{RST}")
                        for p in projects:
                            marker = "●" if p["has_tsunami_md"] else "○"
                            active = " ← active" if p["name"] == active_project else ""
                            print(f"  {marker} {p['name']} ({p['files']} files){active}")
                    print()
                    continue

                cmd = parts[1]
                if cmd == "new" and len(parts) == 3:
                    # Create new project
                    name = parts[2]
                    proj_dir = os.path.join(config.workspace_dir, "deliverables", name)
                    os.makedirs(proj_dir, exist_ok=True)
                    # Create tsunami.md
                    tmd_path = os.path.join(proj_dir, "tsunami.md")
                    with open(tmd_path, "w") as f:
                        f.write(f"# {name}\n\nNew project. Describe what this project is about.\n")
                    active_project = name
                    print(f"  {GREEN}Created project: {name}{RST}")
                    print(f"  {DIM}Edit {tmd_path} to add project context{RST}")
                    print()
                    continue

                # Set active project
                name = cmd
                agent = Agent(config)
                summary = agent.set_project(name)
                if "not found" in summary:
                    print(f"  {RED}{summary}{RST}")
                else:
                    active_project = name
                    print(f"  {summary}")
                print()
                continue

            # ── /serve command ──
            if text.startswith("/serve"):
                parts = text.split()
                port = parts[1] if len(parts) > 1 else "8080"
                if active_project:
                    serve_dir = os.path.join(config.workspace_dir, "deliverables", active_project)
                else:
                    serve_dir = os.path.join(config.workspace_dir, "deliverables")
                import subprocess
                subprocess.Popen(
                    ["python3", "-m", "http.server", port, "--directory", serve_dir],
                    stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
                print(f"  {GREEN}Serving {serve_dir} on http://localhost:{port}{RST}")
                print()
                continue

            # ── Normal task ──
            print()
            agent = Agent(config)
            if active_project:
                agent.set_project(active_project)
            patch_agent(agent)
            try:
                await agent.run(text)
            except KeyboardInterrupt:
                print(f"  {DIM}interrupted{RST}")
            except Exception as e:
                print(f"  {RED}{e}{RST}")
            print()

    try:
        asyncio.run(repl())
    finally:
        if model_proc:
            model_proc.terminate()


if __name__ == "__main__":
    main()
