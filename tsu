#!/bin/bash
# TSUNAMI — Reborn from the Flood
DIR="$(cd "$(dirname "$(realpath "$0")")" && pwd)"
USER_CWD="$PWD"        # remember where the user invoked us
cd "$DIR"              # cd to repo so python imports + relative paths work

# Workspace resolution:
#   - If user ran tsu from inside the repo → use repo's workspace/ (legacy).
#   - If user ran from somewhere else → build there (their project dir).
#   - TSUNAMI_WORKSPACE env var always wins.
if [ -z "${TSUNAMI_WORKSPACE:-}" ]; then
  case "$USER_CWD" in
    "$DIR"|"$DIR"/*) : ;;  # inside repo → leave default
    *) export TSUNAMI_WORKSPACE="$USER_CWD" ;;
  esac
fi
[ -n "${TSUNAMI_WORKSPACE:-}" ] && echo "  workspace: $TSUNAMI_WORKSPACE"

# Auto-update on launch (silent, non-blocking)
if [ -d "$DIR/.git" ]; then
  git branch --set-upstream-to=origin/main main 2>/dev/null
  _local=$(git rev-parse HEAD 2>/dev/null)
  git fetch origin main --quiet 2>/dev/null
  _remote=$(git rev-parse origin/main 2>/dev/null)
  if [ "$_local" != "$_remote" ] 2>/dev/null; then
    git pull --ff-only --quiet 2>/dev/null && \
      echo "  Updated to $(git rev-parse --short HEAD)"
  fi
fi

# Handle commands
case "${1:-}" in
  update)
    echo "  Updating Tsunami..."
    git pull --ff-only && echo "  ✓ Updated to $(git rev-parse --short HEAD)" || echo "  ✗ Update failed"
    exit 0
    ;;
  version)
    echo "Tsunami $(git rev-parse --short HEAD) ($(git log -1 --format=%ci | cut -d' ' -f1))"
    exit 0
    ;;
  swarm)
    shift
    TASK="${1:?Usage: tsunami swarm \"task description\" [num_workers]}"
    WORKERS="${2:-2}"
    python3 -m tsunami.orchestrate "$TASK" "$WORKERS"
    exit $?
    ;;
  kill|stop|down)
    echo "  Tearing down Tsunami stack..."
    # SIGTERM first, give 20s to exit gracefully, then SIGKILL stragglers
    for port in 8090 8091 8092 8093 8094 8095 3000 3002 3003 9876 9200; do
      pids=$(lsof -ti:$port 2>/dev/null)
      [ -n "$pids" ] && kill $pids 2>/dev/null
    done
    for i in $(seq 1 20); do
      any_up=""
      for port in 8090 8091 8092 8093 8094 8095; do
        lsof -ti:$port >/dev/null 2>&1 && any_up=1
      done
      [ -z "$any_up" ] && break
      sleep 1
    done
    for port in 8090 8091 8092 8093 8094 8095 3000 3002 3003 9876 9200; do
      lsof -ti:$port 2>/dev/null | xargs -r kill -9 2>/dev/null
    done
    pkill -f "llama-server" 2>/dev/null
    pkill -f "tsunami.tools.ernie_server" 2>/dev/null
    pkill -f "serve_transformers" 2>/dev/null
    echo "  ✓ All processes killed"
    exit 0
    ;;
  swap)
    kind="${2:-}"
    case "$kind" in
      turbo|Turbo) kind="Turbo" ;;
      base|Base)   kind="Base" ;;
      *) echo "Usage: tsu swap <turbo|base>"; exit 1 ;;
    esac
    resp=$(curl -sf -X POST "http://localhost:8092/v1/admin/swap?kind=$kind" 2>&1)
    if [ $? -eq 0 ]; then
      echo "  ✓ ERNIE swapped to $kind"
      echo "  $resp"
    else
      echo "  ✗ Swap failed — is ernie_server running in bf16 mode? (ERNIE_MODE=bf16 tsu up)"
      exit 1
    fi
    exit 0
    ;;
  up)
    # Bring services up, then exit (no REPL). Implemented by falling through
    # the rest of the startup code with a flag set to skip the interactive frontend.
    TSU_UP_ONLY=1
    ;;
esac

# Stale-port cleanup (per-tier).
for port in 3000 9876 8090 8091 8092 8094; do
  lsof -ti:$port 2>/dev/null | xargs kill -9 2>/dev/null
done

# ---------------------------------------------------------------------------
# Inference stack — coder + VL split:
#   8090 — tsunami proxy   (FastAPI front-end, forwards /v1/chat → 8091,
#                           /v1/images → 8092, undertow vision → 8094)
#   8091 — llama-server    (Qwen3-Coder-Next Q4_K_M — 80B MoE, 3B active,
#                           text-only, coder-specialized)
#   8092 — ernie_server    (image gen, ERNIE-Image-Turbo bf16 swap-capable)
#   8093 — reserved        (future: SDXL+ControlNet for rigid motion library)
#   8094 — llama-server    (Qwen3.5-4B + mmproj — undertow vision QA)
#   8095 — reserved        (future: Wan Animate for unique effect animations)
# ---------------------------------------------------------------------------

# Binary discovery — installer drops these in bin/, or user has them in PATH,
# or they built locally.
find_bin() {
  local name="$1"; shift
  for p in "$(which "$name" 2>/dev/null)" "$@"; do
    [ -n "$p" ] && [ -x "$p" ] && echo "$p" && return
  done
}
LLAMA_BIN=$(find_bin llama-server \
  "$DIR/bin/llama-server" \
  "$HOME/tsunami/llama-server/llama-server" \
  "$HOME/llama.cpp/build/bin/llama-server" \
  "/tmp/llamacpp/build/bin/llama-server")

# Model discovery — honor $TSUNAMI_MODELS_DIR, else check common locations.
MODELS_DIR="${TSUNAMI_MODELS_DIR:-$HOME/models_gguf}"
[ -d "$MODELS_DIR" ] || MODELS_DIR="$DIR/models"
# LM model discovery — coder + VL split architecture
#   :8091 — Qwen3-Coder-Next Q4_K_M (80B MoE, 3B active) — text-only, coder-specialized
#   :8094 — Qwen3.5-4B Q4_K_M + mmproj — undertow vision QA
LM_GGUF=$(ls "$MODELS_DIR"/Qwen3-Coder-Next*.gguf 2>/dev/null | head -1)
VL_GGUF=$(ls "$MODELS_DIR"/Qwen3.5-4B-Q4_K_M.gguf 2>/dev/null | head -1)
VL_MMPROJ=$(ls "$MODELS_DIR"/mmproj-qwen35-4B*.gguf 2>/dev/null | head -1)

# ERNIE uses Baidu snapshot + in-process Mistral3 TE — resolved by the
# ernie_server module via its _find_baidu_snapshot helper (HF cache or
# ~/models_hf). No $MODELS_DIR GGUF lookup needed in --no-gguf mode.
ERNIE_PYTHON="${ERNIE_PYTHON:-python3}"

echo "  models:"
echo "    LM:   $(basename "${LM_GGUF:-(missing)}")  (coder)"
echo "    VL:   $(basename "${VL_GGUF:-(missing)}")  (undertow vision)"
echo "    DiT:  ERNIE-Image-Turbo (bf16, swap-capable → Base)"

# --- :8091 llama-server (coder, text-only) ---
# Qwen3-Coder-Next: 80B MoE, 3B active, text-only, no thinking mode.
# README recommended: temp=1.0, top_p=0.95, top_k=40, max_tokens=65536.
# -c 16384 keeps KV cache manageable alongside ERNIE + VL.
if [ -n "$LLAMA_BIN" ] && [ -n "$LM_GGUF" ] && ! curl -sf http://localhost:8091/health >/dev/null 2>&1; then
  echo "  starting coder llama-server → :8091"
  nohup "$LLAMA_BIN" -m "$LM_GGUF" \
    --port 8091 --host 0.0.0.0 -ngl 999 -c 16384 --jinja -fa on \
    > /tmp/tsu-llama.log 2>&1 &
fi

# --- :8094 llama-server (VL model for undertow vision QA) ---
# Qwen3.5-4B Q4_K_M + mmproj — natively multimodal. Handles image inputs
# from undertow screenshots. -c 8192 small context, -ngl 999 full offload.
if [ -n "$LLAMA_BIN" ] && [ -n "$VL_GGUF" ] && [ -n "$VL_MMPROJ" ] && ! curl -sf http://localhost:8094/health >/dev/null 2>&1; then
  echo "  starting VL llama-server → :8094"
  nohup "$LLAMA_BIN" -m "$VL_GGUF" --mmproj "$VL_MMPROJ" \
    --port 8094 --host 0.0.0.0 -ngl 999 -c 8192 --jinja -fa on \
    > /tmp/tsu-vl.log 2>&1 &
fi

# --- :8092 ernie_server (image gen) ---
# ERNIE_MODE knob:
#   gguf   = Q4_K_M Turbo DiT (~5 GB, fastest)
#   bf16   = bf16 Turbo DiT (~16 GB, /v1/admin/swap → Base works)
#   base   = bf16 ERNIE-Image Base (~16 GB, 50-step keeper quality)
# Default bf16 because swap-capable wins for everyday use.
ERNIE_MODE="${ERNIE_MODE:-bf16}"
case "$ERNIE_MODE" in
  bf16)  ERNIE_ARGS="--no-gguf --model Turbo"; ERNIE_DESC="Turbo bf16 (16 GB, swap-capable)" ;;
  base)  ERNIE_ARGS="--no-gguf --model Base";  ERNIE_DESC="Base (16 GB, 50-step keeper)" ;;
  gguf)  ERNIE_GGUF_FILE="${MODELS_DIR}/ernie-image-turbo-Q4_K_M.gguf"
         ERNIE_ARGS="--gguf $ERNIE_GGUF_FILE --model Turbo"
         ERNIE_DESC="Turbo Q4_K_M (5 GB)" ;;
  *)     echo "  unknown ERNIE_MODE=$ERNIE_MODE (pick gguf|bf16|base)"; exit 1 ;;
esac
if ! curl -sf http://localhost:8092/healthz >/dev/null 2>&1; then
  echo "  starting ernie_server → :8092 ($ERNIE_DESC)"
  PYTHONPATH="$DIR" \
  nohup "$ERNIE_PYTHON" -m tsunami.tools.ernie_server \
    $ERNIE_ARGS \
    --port 8092 --host 0.0.0.0 \
    --pe-url "" \
    > /tmp/tsu-ernie.log 2>&1 &
fi

# --- :8090 tsunami proxy (forwards to LM + image gen, hosts undertow) ---
check_proxy() { curl -sf http://localhost:8090/health >/dev/null 2>&1; }
if ! check_proxy; then
  echo "  starting tsunami proxy → :8090"
  LLAMA_SERVER_URL=http://localhost:8091 \
  SD_SERVER_URL=http://localhost:8092 \
  PYTHONPATH="$DIR" \
  nohup python3 -u "$DIR/tsunami/serve_transformers.py" \
    --model none --image-model none \
    --port 8090 --host 0.0.0.0 \
    > /tmp/tsu-proxy.log 2>&1 &
fi

# Wait for all tiers (180s ceiling — ERNIE bf16 + Coder-Next + VL cold-loads in parallel).
echo "  waiting for stack..."
for i in $(seq 1 180); do
  curl -sf http://localhost:8091/health  >/dev/null 2>&1 && \
  curl -sf http://localhost:8092/healthz >/dev/null 2>&1 && \
  curl -sf http://localhost:8094/health  >/dev/null 2>&1 && \
  check_proxy && break
  sleep 1
done

# `tsu up` → skip REPL launch, just report stack state and exit.
if [ -n "${TSU_UP_ONLY:-}" ]; then
  echo ""
  echo "─── Stack ready ───────────────────────────────────────────────"
  echo "  :8090  tsunami proxy              tail -f /tmp/tsu-proxy.log"
  echo "  :8091  Gemma-4-26B-A4B (LM)       tail -f /tmp/tsu-llama.log"
  echo "  :8092  ERNIE-Image ($ERNIE_MODE)  tail -f /tmp/tsu-ernie.log"
  echo ""
  echo "  Health:  curl :8090/health   curl :8091/health   curl :8092/healthz"
  echo "  Swap :   tsu swap base       tsu swap turbo       (bf16 mode only)"
  echo "  Down :   tsu down"
  echo ""
  exit 0
fi

# Start Python WebSocket backend if not running
if ! curl -sf http://localhost:3000/api/health > /dev/null 2>&1; then
  python3 -c "
import sys; sys.path.insert(0,'$DIR')
from tsunami.server import start_server
start_server(host='0.0.0.0', port=3000)
" > /tmp/tsunami_server.log 2>&1 &
  SERVER_PID=$!
  for i in $(seq 1 10); do
    curl -sf http://localhost:3000/api/health > /dev/null 2>&1 && break
    sleep 0.5
  done
fi

# Start serve daemon (auto-serves latest deliverable on :9876)
DAEMON_PID=""
if [ -f "$DIR/tsunami/serve_daemon.py" ]; then
  python3 -m tsunami.serve_daemon --workspace "$DIR/workspace" --port 9876 > /tmp/tsunami_daemon.log 2>&1 &
  DAEMON_PID=$!
fi

cleanup() {
  [ -n "$SERVER_PID" ] && kill $SERVER_PID 2>/dev/null
  [ -n "$MODEL_PID" ] && kill $MODEL_PID 2>/dev/null
  [ -n "$BRIDGE_PID" ] && kill $BRIDGE_PID 2>/dev/null
  [ -n "$WATCHER_PID" ] && kill $WATCHER_PID 2>/dev/null
  [ -n "$DAEMON_PID" ] && kill $DAEMON_PID 2>/dev/null
}
trap cleanup EXIT

# Show the UI URL
LOCAL_IP=$(hostname -I 2>/dev/null | awk '{print $1}' || echo "localhost")
echo ""
echo "  UI: http://${LOCAL_IP}:3000"
echo "  UI: http://localhost:3000"
echo ""

# Launch frontend — Ink CLI if Node available, Python fallback otherwise
if command -v npx &>/dev/null && [ -d "$DIR/cli/node_modules" ]; then
  cd "$DIR/cli"
  exec npx tsx app.jsx "$@"
else
  # Python fallback — simple REPL that talks to the agent
  cd "$DIR"
  exec python3 -c "
import sys, asyncio
sys.path.insert(0, '$DIR')
from tsunami.agent import Agent
from tsunami.config import TsunamiConfig

async def main():
    config = TsunamiConfig.from_yaml('config.yaml')
    config = TsunamiConfig.from_env(config)
    agent = Agent(config)
    print('TSUNAMI — type a task, press Enter. Type exit to quit.')
    print()
    while True:
        try:
            task = input('> ')
        except (EOFError, KeyboardInterrupt):
            break
        if task.strip().lower() in ('exit', 'quit', 'q'):
            break
        if not task.strip():
            continue
        result = await agent.run(task)
        print(result)
        print()

asyncio.run(main())
"
fi
