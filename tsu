#!/bin/bash
# TSUNAMI — Reborn from the Flood
DIR="$(cd "$(dirname "$(realpath "$0")")" && pwd)"
cd "$DIR"

# Auto-update on launch (silent, non-blocking)
if [ -d "$DIR/.git" ]; then
  git branch --set-upstream-to=origin/main main 2>/dev/null
  _local=$(git rev-parse HEAD 2>/dev/null)
  git fetch origin main --quiet 2>/dev/null
  _remote=$(git rev-parse origin/main 2>/dev/null)
  if [ "$_local" != "$_remote" ] 2>/dev/null; then
    git pull --ff-only --quiet 2>/dev/null && \
      echo "  Updated to $(git rev-parse --short HEAD)"
  fi
fi

# Handle commands
case "${1:-}" in
  update)
    echo "  Updating Tsunami..."
    git pull --ff-only && echo "  ✓ Updated to $(git rev-parse --short HEAD)" || echo "  ✗ Update failed"
    exit 0
    ;;
  version)
    echo "Tsunami $(git rev-parse --short HEAD) ($(git log -1 --format=%ci | cut -d' ' -f1))"
    exit 0
    ;;
  swarm)
    shift
    TASK="${1:?Usage: tsunami swarm \"task description\" [num_workers]}"
    WORKERS="${2:-2}"
    python3 -m tsunami.orchestrate "$TASK" "$WORKERS"
    exit $?
    ;;
  kill|stop)
    echo "  Killing all Tsunami processes..."
    # Kill model servers
    for port in 8090 8092 8094; do
      lsof -ti:$port 2>/dev/null | xargs kill -9 2>/dev/null
    done
    # Kill web services
    for port in 3000 3002 3003 9876; do
      lsof -ti:$port 2>/dev/null | xargs kill -9 2>/dev/null
    done
    # Kill any remaining tsunami/llama processes
    pkill -f "llama-server" 2>/dev/null
    pkill -f "tsunami" 2>/dev/null
    pkill -f "serve_diffusion" 2>/dev/null
    pkill -f "tsunami_daemon_start" 2>/dev/null
    pkill -f "tsunami_server_start" 2>/dev/null
    echo "  ✓ All processes killed"
    exit 0
    ;;
esac

# Kill stale servers from previous runs
for port in 3000 9876; do
  lsof -ti:$port 2>/dev/null | xargs kill -9 2>/dev/null
done

# Check model server
check_model() { curl -sf http://localhost:8090/health > /dev/null 2>&1; }

if ! check_model; then
  # Find llama-server — check common locations
  LLAMA=""
  for p in \
    "$(which llama-server 2>/dev/null)" \
    "$DIR/llama-server/llama-server" \
    "$DIR/llama.cpp/build/bin/llama-server" \
    "$HOME/tsunami/llama-server/llama-server" \
    "$HOME/llama.cpp/build/bin/llama-server" \
    "/usr/local/bin/llama-server"; do
    [ -x "$p" ] && LLAMA="$p" && break
  done

  # Detect available memory — VRAM if GPU, RAM otherwise
  VRAM_GB=0
  if command -v nvidia-smi &>/dev/null; then
    VRAM_MB=$(nvidia-smi --query-gpu=memory.total --format=csv,noheader,nounits 2>/dev/null | head -1 | tr -d ' ')
    [ -n "$VRAM_MB" ] && [ "$VRAM_MB" != "[N/A]" ] && VRAM_GB=$(( (VRAM_MB + 1023) / 1024 ))
  fi
  if [ "$VRAM_GB" -eq 0 ] 2>/dev/null; then
    # No GPU or unified memory — use RAM
    if [ "$(uname -s)" = "Darwin" ]; then
      VRAM_GB=$(sysctl -n hw.memsize 2>/dev/null | awk '{print int($1/1073741824)}')
    else
      VRAM_GB=$(free -g 2>/dev/null | awk '/^Mem:/{print $2}')
    fi
  fi
  VRAM_GB=${VRAM_GB:-8}
  DEGRADED=false
  if [ "$VRAM_GB" -lt 8 ] 2>/dev/null; then
    DEGRADED=true
    echo "  ${VRAM_GB}GB available — degraded mode (reduced context)"
  else
    echo "  ${VRAM_GB}GB available — full mode"
  fi

  # Model: Gemma 4 E4B (single model for all roles)
  GEMMA_MODEL=$(ls models/gemma-4-E4B*.gguf 2>/dev/null | head -1)
  # Fallback: any .gguf model
  if [ -z "$GEMMA_MODEL" ]; then
    GEMMA_MODEL=$(ls models/gemma*.gguf models/Qwen*.gguf 2>/dev/null | head -1)
  fi

  if [ -n "$GEMMA_MODEL" ] && [ -f "$LLAMA" ]; then
    CTX_SIZE=16384
    [ "$DEGRADED" = "true" ] && CTX_SIZE=8192
    echo "  starting $(basename $GEMMA_MODEL)"
    "$LLAMA" --model "$GEMMA_MODEL" \
      --host 0.0.0.0 --port 8090 \
      --ctx-size $CTX_SIZE --parallel 2 --n-gpu-layers 99 -fa on \
      > /tmp/llama-server.log 2>&1 &
    MODEL_PID=$!
  fi

  if [ -n "$MODEL_PID" ]; then
    echo "  waiting for model to load..."
    for i in $(seq 1 120); do check_model && break; sleep 1; done
  fi
fi

# Start Python WebSocket backend if not running
if ! curl -sf http://localhost:3000/api/health > /dev/null 2>&1; then
  python3 -c "
import sys; sys.path.insert(0,'$DIR')
from tsunami.server import start_server
start_server(host='0.0.0.0', port=3000)
" > /tmp/tsunami_server.log 2>&1 &
  SERVER_PID=$!
  for i in $(seq 1 10); do
    curl -sf http://localhost:3000/api/health > /dev/null 2>&1 && break
    sleep 0.5
  done
fi

# Start serve daemon (auto-serves latest deliverable on :9876)
DAEMON_PID=""
if [ -f "$DIR/tsunami/serve_daemon.py" ]; then
  python3 -m tsunami.serve_daemon --workspace "$DIR/workspace" --port 9876 > /tmp/tsunami_daemon.log 2>&1 &
  DAEMON_PID=$!
fi

cleanup() {
  [ -n "$SERVER_PID" ] && kill $SERVER_PID 2>/dev/null
  [ -n "$MODEL_PID" ] && kill $MODEL_PID 2>/dev/null
  [ -n "$BRIDGE_PID" ] && kill $BRIDGE_PID 2>/dev/null
  [ -n "$WATCHER_PID" ] && kill $WATCHER_PID 2>/dev/null
  [ -n "$DAEMON_PID" ] && kill $DAEMON_PID 2>/dev/null
}
trap cleanup EXIT

# Show the UI URL
LOCAL_IP=$(hostname -I 2>/dev/null | awk '{print $1}' || echo "localhost")
echo ""
echo "  UI: http://${LOCAL_IP}:3000"
echo "  UI: http://localhost:3000"
echo ""

# Launch frontend — Ink CLI if Node available, Python fallback otherwise
if command -v npx &>/dev/null && [ -d "$DIR/cli/node_modules" ]; then
  cd "$DIR/cli"
  exec npx tsx app.jsx "$@"
else
  # Python fallback — simple REPL that talks to the agent
  cd "$DIR"
  exec python3 -c "
import sys, asyncio
sys.path.insert(0, '$DIR')
from tsunami.agent import Agent
from tsunami.config import TsunamiConfig

async def main():
    config = TsunamiConfig.from_yaml('config.yaml')
    config = TsunamiConfig.from_env(config)
    agent = Agent(config)
    print('TSUNAMI — type a task, press Enter. Type exit to quit.')
    print()
    while True:
        try:
            task = input('> ')
        except (EOFError, KeyboardInterrupt):
            break
        if task.strip().lower() in ('exit', 'quit', 'q'):
            break
        if not task.strip():
            continue
        result = await agent.run(task)
        print(result)
        print()

asyncio.run(main())
"
fi
